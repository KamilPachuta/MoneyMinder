@using Client.Models.ReadModels
@using Client.Services.Interfaces
@using MoneyMinderClient.Models
@using Client.Components.Dialogs
@using MoneyMinderClient.Services.Interfaces
@inject ICurrencyAccountService CurrencyService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IAccountService AccountService



<AuthorizeView>
    <Authorized>
        @if (!string.IsNullOrWhiteSpace(name))
        {
            <MudDrawerHeader>
                <MudText Typo="Typo.h6">@name</MudText>
            </MudDrawerHeader>
        }
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home">Home</MudNavLink> 
            <MudNavGroup Title="CurrencyAccounts" Icon="@Icons.Material.Filled.AccountBalanceWallet" Expanded="true">
                @foreach (var account in _currencyAccountNames)
                {
                    <MudPaper Outlined="true" Class="px-3 py-1" Elevation="5">
                        <MudNavGroup Title="@account.Name" Icon="@Icons.Material.Filled.ReadMore" Expanded="false" Class="">
                            <MudNavLink Href="@CurrencyAccountLinkBuilder.Path(account.Name)" Icon="@Icons.Material.Filled.AttachMoney">Account</MudNavLink>
                            <MudNavLink Href="@CurrencyAccountLinkBuilder.TransactionHistoryPath(account.Name)" Icon="@Icons.Material.Filled.History">Transaction History</MudNavLink>
                            <MudNavLink Href="@CurrencyAccountLinkBuilder.MonthlyTransactionsPath(account.Name)" Icon="@Icons.Material.Filled.EventRepeat">Monthly Transactions</MudNavLink>
                            <MudNavLink Href="@CurrencyAccountLinkBuilder.BudgetPath(account.Name)" Icon="@Icons.Material.Filled.BarChart">Budget</MudNavLink>
                        </MudNavGroup>
                    </MudPaper>
                }
                <MudNavLink Icon="@Icons.Material.Filled.AddCard" OnClick="CreateCurrencyAccount">Create</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Savings" Icon="@Icons.Material.Filled.Savings" Expanded="true">
                <MudNavLink Href="/savings" Icon="@Icons.Material.Filled.Receipt">Savings</MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.AddCard" OnClick="CreateSavings">Create</MudNavLink>
            </MudNavGroup>  
        </MudNavMenu>
    </Authorized>
</AuthorizeView>
@code {
    private List<CurrencyAccountNameModel> _currencyAccountNames = new();
    private List<string> _errorList;
    private string name = "";

    private async Task CreateSavings()
    {
        throw new NotImplementedException();
    }
    
    private async Task CreateCurrencyAccount()
    {
        var dialog = await DialogService.ShowAsync<NewCurrencyAccount>();
        
        var result = await dialog.Result;

        var isSucces = new Result();
        
        if (!result.Canceled)
        {
            isSucces  = await dialog.GetReturnValueAsync<Result>();
        }
        
        if (isSucces.Succeeded)
        {
            Snackbar.Add("Submitted creating currency account.");
        }
        else
        {
            Snackbar.Add("Saving error!");
            foreach (var error in isSucces.ErrorList)
            {
                Snackbar.Add(error);
            }
        }
    }

    private async Task SetParams()
    {
        var response = await CurrencyService.GetCurrencyAccountNames();
        if (response.Succeeded)
        {
            _currencyAccountNames = response.Response.CurrencyAccountNames.ToList();
        }
        else
        {
            _errorList = response.ErrorList;
        }
        
        name = await AccountService.GetName();
        
    }
    
    protected override async Task OnInitializedAsync()
    {
        await SetParams();
    }

    
    private static class CurrencyAccountLinkBuilder
    {
        public static string Path(string name) => $"/CurrencyAccount/{name}";

        public static string TransactionHistoryPath(string name) => $"/CurrencyAccount/{name}/TransactionHistory";
        
        public static string MonthlyTransactionsPath(string name) => $"/CurrencyAccount/{name}/MonthlyTransactions";
        
        public static string BudgetPath(string name) => $"/CurrencyAccount/{name}/Budget";
        
    }
    
    
}
 
